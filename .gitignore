# Environment — contains secrets
.env
.env.*
!.env.example

# Data directories — ignore file contents, keep directory structure via .gitkeep
data/raw/*
!data/raw/.gitkeep
data/cleaned/*
!data/cleaned/.gitkeep
data/enriched/*
!data/enriched/.gitkeep
data/final/*
!data/final/.gitkeep

# Logs — ignore file contents, keep directory structure
logs/*
!logs/.gitkeep

# Jobs — ignore runtime job files, keep directory structure
jobs/queued/*
!jobs/queued/.gitkeep
jobs/processing/*
!jobs/processing/.gitkeep
jobs/completed/*
!jobs/completed/.gitkeep
jobs/failed/*
!jobs/failed/.gitkeep

# Node
node_modules/
npm-debug.log*

# Next.js
app/.next/
app/out/
app/node_modules/
app/tsconfig.tsbuildinfo

# Pending job configs
jobs/pending/*
!jobs/pending/.gitkeep

# Checkpoints — runtime resume state, never committed
jobs/checkpoints/*
!jobs/checkpoints/.gitkeep

# Domain cache — stays local, never committed
config/domain-cache.json

# Google service account key — contains private key, never committed
config/google-service-account.json

# OS
.DS_Store
Thumbs.db
