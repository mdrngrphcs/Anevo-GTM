# Anevo-GTM Environment Variables
# Copy this file to .env and fill in your real API keys.
# Never commit .env to version control.

# Data Sourcing
APOLLO_API_KEY=your_apollo_api_key_here
AI_ARK_API_KEY=your_aiark_api_key_here
LISTMINT_API_KEY=your_listmint_key_here

# Email Verification
MILLIONVERIFIER_API_KEY=your_millionverifier_key_here

# AI / LLM Providers
OPENROUTER_API_KEY=your_openrouter_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Future Integrations
PROSPEO_API_KEY=your_prospeo_key_here
FINDYMAIL_API_KEY=your_findymail_key_here

# Google Drive — paste entire service account JSON as a single line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
# Required when the Drive folder is in a personal My Drive (not a Shared Drive).
# Set to the email of the folder owner. Requires domain-wide delegation on the
# service account (Google Workspace Admin Console → Security → API controls).
GOOGLE_IMPERSONATE_EMAIL=owner@yourdomain.com
